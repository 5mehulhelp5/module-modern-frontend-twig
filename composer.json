{
    "name": "mage-obsidian/module-modern-frontend-twig",
    "description": "Optional Twig template engine for MageObsidian ModernFrontend. Installing it registers a .twig engine alongside Magento's native .phtml.",
    "keywords": [
        "magento",
        "magento2",
        "frontend",
        "vite",
        "vue",
        "tailwindcss",
        "twig",
        "template-engine"
    ],
    "homepage": "https://mage-obsidian.jeanmarcos.dev/",
    "support": {
        "issues": "https://github.com/mage-obsidian/module-modern-frontend-twig/issues",
        "docs": "https://mage-obsidian.jeanmarcos.dev/",
        "source": "https://github.com/mage-obsidian/module-modern-frontend-twig"
    },
    "authors": [
        {
            "name": "Jeanmarcos Juarez",
            "homepage": "https://github.com/jeanmarcos-dev"
        }
    ],
    "require": {
        "mage-obsidian/module-modern-frontend": "^2.0",
        "twig/twig": "^3.12"
    },
    "type": "magento2-module",
    "license": [
        "MIT"
    ],
    "autoload": {
        "files": [
            "src/registration.php"
        ],
        "psr-4": {
            "MageObsidian\\ModernFrontendTwig\\": "src/"
        }
    }
}
